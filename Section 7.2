for i in [1..4] do;
x:=Pts[i][1];
y:=Pts[i][2];
z:=Pts[i][3];
w:=Pts[i][4];
t:=Pts[i][5];
Evaluate(map_0_coord_0,[x,y,z,w,t]);
Evaluate(map_0_coord_1,[x,y,z,w,t]); // j-invariant is quotient of these
print ".....";
end for;

